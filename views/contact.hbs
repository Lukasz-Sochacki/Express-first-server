<html lang='en' dir='ltr'>

  <h2>Contact me</h2>

  {{#if isSent}}
    <div class='isSent'>
      <p>The message has been sent!</p>
      <br />
      <p>File {{fileName}} has been saved!</p>
    </div>
  {{/if}}

  {{#if isError}}
    <div class='isError'>
      <p>You can't leave fields empty!</p>
    </div>
  {{/if}}

  {{#if isErrorFile}}
    <div class='isError'>
      You have to upload at least one file!
    </div>
  {{/if}}
  <form
    action='/contact/send-message'
    method='POST'
    enctype='multipart/form-data'
  >
    <label>
      Your name:
      {{! 'name' attributes are the 'key' attributes in Postman }}
      <input type='text' name='author' />
    </label>

    <label>
      Your email:
      <input type='email' name='sender' />
    </label>

    <label>
      Title:
      <input type='text' name='title' />
    </label>

    <label>
      Project design:
      <input type='file' name='file' accept='.jpg, .jpeg, .png' />
    </label>

    <label>
      Message:
      <textarea name='message'></textarea>
    </label>
    <button type='submit'>Send message</button>
  </form>

</html>